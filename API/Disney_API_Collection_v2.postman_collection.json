{
  "info": {
    "name": "Disney API — Automation Suite (Fixed)",
    "_postman_id": "disney-api-test-suite-v2",
    "description": "Newman/Postman automation suite for https://api.disneyapi.dev\nv2 — Tests corrected to reflect actual API behavior discovered in first run.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://api.disneyapi.dev", "type": "string" },
    { "key": "tvShow", "value": "Jake and the Never Land Pirates", "type": "string" },
    { "key": "videoGame", "value": "Kingdom Hearts III", "type": "string" }
  ],
  "item": [

    {
      "name": "1 — Fetch All Characters",
      "item": [

        {
          "name": "1.1 GET /character — Status 200 & Top-level Structure",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Content-Type is application/json', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('Response has required top-level keys', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.all.keys('info', 'data');",
                  "});",
                  "",
                  "pm.test('info object has correct pagination fields', () => {",
                  "    const { info } = pm.response.json();",
                  "    pm.expect(info).to.be.an('object');",
                  "    pm.expect(info).to.have.all.keys('totalPages', 'count', 'previousPage', 'nextPage');",
                  "    pm.expect(info.totalPages).to.be.a('number').and.to.be.above(0);",
                  "    pm.expect(info.count).to.be.a('number').and.to.be.above(0);",
                  "});",
                  "",
                  "pm.test('data is a non-empty array', () => {",
                  "    const { data } = pm.response.json();",
                  "    pm.expect(data).to.be.an('array').and.to.have.length.above(0);",
                  "});",
                  "",
                  "pm.test('Each character has required fields with correct types', () => {",
                  "    const { data } = pm.response.json();",
                  "    data.forEach((char, i) => {",
                  "        pm.expect(char, `char[${i}] missing _id`).to.have.property('_id');",
                  "        pm.expect(char._id, `char[${i}]._id not a number`).to.be.a('number');",
                  "        pm.expect(char, `char[${i}] missing name`).to.have.property('name');",
                  "        pm.expect(char.name, `char[${i}].name not a string`).to.be.a('string').and.not.empty;",
                  "        pm.expect(char, `char[${i}] missing films`).to.have.property('films');",
                  "        pm.expect(char.films, `char[${i}].films not an array`).to.be.an('array');",
                  "        pm.expect(char, `char[${i}] missing tvShows`).to.have.property('tvShows');",
                  "        pm.expect(char.tvShows, `char[${i}].tvShows not an array`).to.be.an('array');",
                  "        pm.expect(char, `char[${i}] missing videoGames`).to.have.property('videoGames');",
                  "        pm.expect(char.videoGames, `char[${i}].videoGames not an array`).to.be.an('array');",
                  "        pm.expect(char, `char[${i}] missing url`).to.have.property('url');",
                  "        pm.expect(char.url, `char[${i}].url not a string`).to.be.a('string').and.not.empty;",
                  "    });",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('totalPages', body.info.totalPages);",
                  "pm.collectionVariables.set('pageCount', body.info.count);",
                  "pm.collectionVariables.set('nextPage', body.info.nextPage || '');",
                  "console.log('totalPages:', body.info.totalPages, '| count:', body.info.count);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/character", "host": ["{{baseUrl}}"], "path": ["character"] }
          }
        },

        {
          "name": "1.2 GET /character?page=1 — Explicit Page 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 for page=1', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Page 1 returns data array', () => {",
                  "    const { data } = pm.response.json();",
                  "    pm.expect(data).to.be.an('array').and.to.have.length.above(0);",
                  "});",
                  "",
                  "pm.test('previousPage is null on page 1', () => {",
                  "    const { info } = pm.response.json();",
                  "    pm.expect(info.previousPage).to.be.null;",
                  "});",
                  "",
                  "pm.test('nextPage is a string URL on page 1', () => {",
                  "    const { info } = pm.response.json();",
                  "    pm.expect(info.nextPage).to.be.a('string').and.to.match(/page=2/);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/character?page=1",
              "host": ["{{baseUrl}}"],
              "path": ["character"],
              "query": [{ "key": "page", "value": "1" }]
            }
          }
        },

        {
          "name": "1.3 GET /character?page=2 — Page 2 Pagination",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 for page=2', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Page 2 has previousPage pointing to page=1', () => {",
                  "    const { info } = pm.response.json();",
                  "    pm.expect(info.previousPage).to.be.a('string').and.to.match(/page=1/);",
                  "});",
                  "",
                  "pm.test('Page 2 data is non-empty', () => {",
                  "    const { data } = pm.response.json();",
                  "    pm.expect(data).to.be.an('array').and.to.have.length.above(0);",
                  "});",
                  "",
                  "pm.test('Page 2 count matches page 1 count', () => {",
                  "    const { info } = pm.response.json();",
                  "    const storedCount = pm.collectionVariables.get('pageCount');",
                  "    if (storedCount) {",
                  "        pm.expect(info.count).to.equal(Number(storedCount));",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/character?page=2",
              "host": ["{{baseUrl}}"],
              "path": ["character"],
              "query": [{ "key": "page", "value": "2" }]
            }
          }
        },

        {
          "name": "1.4 GET /character?pageSize=5 — Custom Page Size",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 for pageSize=5', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('data array length does not exceed requested pageSize', () => {",
                  "    const { data } = pm.response.json();",
                  "    pm.expect(data.length).to.be.at.most(5);",
                  "});",
                  "",
                  "pm.test('info.count matches actual data length', () => {",
                  "    const { info, data } = pm.response.json();",
                  "    pm.expect(info.count).to.equal(data.length);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/character?pageSize=5",
              "host": ["{{baseUrl}}"],
              "path": ["character"],
              "query": [{ "key": "pageSize", "value": "5" }]
            }
          }
        },

        {
          "name": "1.5 GET /character/:id — Single Character by ID",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('knownCharId', '308');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 for single character', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Response has info and data keys', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.all.keys('info', 'data');",
                  "});",
                  "",
                  "pm.test('data._id matches requested ID', () => {",
                  "    const { data } = pm.response.json();",
                  "    const requestedId = parseInt(pm.collectionVariables.get('knownCharId'));",
                  "    pm.expect(data._id).to.equal(requestedId);",
                  "});",
                  "",
                  "pm.test('Single character has all required fields', () => {",
                  "    const { data } = pm.response.json();",
                  "    ['_id','name','films','tvShows','videoGames','url'].forEach(field => {",
                  "        pm.expect(data, `missing field: ${field}`).to.have.property(field);",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/character/{{knownCharId}}",
              "host": ["{{baseUrl}}"],
              "path": ["character", "{{knownCharId}}"]
            }
          }
        }

      ]
    },

    {
      "name": "2 — Filter by TV Show (Jake and the Never Land Pirates)",
      "item": [

        {
          "name": "2.1 GET /character?tvShows=Jake... — Status & Results Exist",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('data is a non-empty array', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.data).to.be.an('array').and.to.have.length.above(0);",
                  "});",
                  "",
                  "// FIX #1: removed duplicate const {data} declaration — use body.data throughout",
                  "pm.test('Every character contains the TV show in their tvShows array', () => {",
                  "    const body = pm.response.json();",
                  "    body.data.forEach((char, i) => {",
                  "        const found = char.tvShows.some(show =>",
                  "            show.toLowerCase().includes('jake') ||",
                  "            show.toLowerCase().includes('never land')",
                  "        );",
                  "        pm.expect(found, `char[${i}] '${char.name}' not in expected show`).to.be.true;",
                  "    });",
                  "});",
                  "",
                  "pm.test('info object is present and valid', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.info).to.have.all.keys('totalPages', 'count', 'previousPage', 'nextPage');",
                  "    pm.expect(body.info.count).to.be.a('number').and.to.be.above(0);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('tvShowResultCount', body.data.length);",
                  "console.log('Jake characters found:', body.data.map(c => c.name));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/character?tvShows={{tvShow}}",
              "host": ["{{baseUrl}}"],
              "path": ["character"],
              "query": [{ "key": "tvShows", "value": "{{tvShow}}" }]
            }
          }
        },

        {
          "name": "2.2 GET /character?tvShows=Jake... — Character Schema Validation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Each character has correct field types', () => {",
                  "    const { data } = pm.response.json();",
                  "    data.forEach((char, i) => {",
                  "        pm.expect(char._id, `[${i}]._id`).to.be.a('number');",
                  "        pm.expect(char.name, `[${i}].name`).to.be.a('string').and.not.empty;",
                  "        pm.expect(char.tvShows, `[${i}].tvShows`).to.be.an('array');",
                  "        pm.expect(char.films, `[${i}].films`).to.be.an('array');",
                  "        pm.expect(char.videoGames, `[${i}].videoGames`).to.be.an('array');",
                  "        pm.expect(char.url, `[${i}].url`).to.be.a('string').and.match(/^https?:\\/\\//);",
                  "    });",
                  "});",
                  "",
                  "pm.test('No duplicate _ids in results', () => {",
                  "    const { data } = pm.response.json();",
                  "    const ids = data.map(c => c._id);",
                  "    const unique = new Set(ids);",
                  "    pm.expect(unique.size).to.equal(ids.length);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/character?tvShows={{tvShow}}",
              "host": ["{{baseUrl}}"],
              "path": ["character"],
              "query": [{ "key": "tvShows", "value": "{{tvShow}}" }]
            }
          }
        }

      ]
